              <calculation class='tableau' formula='IF [Calculation_0977528343605248] &lt;= 3 THEN &quot;0-3 Days (Last Minute)&quot;&#13;&#10;ELSEIF [Calculation_0977528343605248] &lt;= 7 THEN &quot;4-7 Days (Short Lead)&quot;&#13;&#10;ELSEIF [Calculation_0977528343605248] &lt;= 14 THEN &quot;8-14 Days (Sweet Spot?)&quot;&#13;&#10;ELSEIF [Calculation_0977528343605248] &lt;= 30 THEN &quot;15-30 Days (Standard)&quot;&#13;&#10;ELSE &quot;31+ Days (Early Bird)&quot;&#13;&#10;END' />
