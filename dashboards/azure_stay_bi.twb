    <worksheet name='Hypo4.2'>
      <table>
        <view>
          <datasources>
            <datasource caption='fact_bookings+' name='federated.1ls00v01j0wdw4172bg260x8o4dy' />
          </datasources>
          <datasource-dependencies datasource='federated.1ls00v01j0wdw4172bg260x8o4dy'>
            <column caption='Potential Revenue Loss' datatype='real' name='[Calculation_0454434656530432]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='// คำนวณว่าถ้าคนกลุ่มที่ใช้ Promo เปลี่ยนมาจ่ายราคา Rack Rate เราจะได้เงินเพิ่มเท่าไหร่&#13;&#10;(AVG(IF [rate_name] = &apos;Rack Rate&apos; THEN [total_room_revenue]/[Calculation_0547067073482753] END) &#13;&#10;- AVG(IF [rate_name] = &apos;Seasonal Promo&apos; THEN [total_room_revenue]/[Calculation_0547067073482753] END))&#13;&#10;* COUNTD(IF [rate_name] = &apos;Seasonal Promo&apos; AND [season] = &apos;High&apos; THEN [booking_id] END)' />
            </column>
            <column aggregation='Sum' caption='LOS' datatype='integer' name='[Calculation_0547067073482753]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, [check_in_date], [check_out_date])' />
            </column>
            <column caption='ADR' datatype='real' default-format='C1054%' name='[Calculation_1171314460160002]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([total_room_revenue]) / COUNT([booking_id])' />
            </column>
            <column caption='Booking Id' datatype='string' name='[booking_id]' role='dimension' type='nominal' />
            <column caption='Check In Date' datatype='date' name='[check_in_date]' role='dimension' type='ordinal' />
            <column caption='Check Out Date' datatype='date' name='[check_out_date]' role='dimension' type='ordinal' />
            <column-instance column='[rate_name]' derivation='None' name='[none:rate_name:nk]' pivot='key' type='nominal' />
            <column-instance column='[season]' derivation='None' name='[none:season:nk]' pivot='key' type='nominal' />
            <column caption='Rate Name' datatype='string' name='[rate_name]' role='dimension' type='nominal' />
            <column caption='Season' datatype='string' name='[season]' role='dimension' type='nominal' />
            <column caption='Total Room Revenue' datatype='real' name='[total_room_revenue]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_0454434656530432]' derivation='User' name='[usr:Calculation_0454434656530432:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1171314460160002]' derivation='User' name='[usr:Calculation_1171314460160002:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.1ls00v01j0wdw4172bg260x8o4dy].[none:season:nk]'>
            <groupfilter function='member' level='[none:season:nk]' member='&quot;High&quot;' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />
          </filter>
          <slices>
            <column>[federated.1ls00v01j0wdw4172bg260x8o4dy].[none:season:nk]</column>
          </slices>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Automatic' />
            <encodings>
              <color column='[federated.1ls00v01j0wdw4172bg260x8o4dy].[none:season:nk]' />
              <text column='[federated.1ls00v01j0wdw4172bg260x8o4dy].[usr:Calculation_0454434656530432:qk]' />
            </encodings>
            <style>
              <style-rule element='mark'>
                <format attr='mark-labels-cull' value='true' />
                <format attr='mark-labels-show' value='true' />
              </style-rule>
            </style>
          </pane>
        </panes>
