    <worksheet name='Hypo7.1'>
      <layout-options>
        <title>
          <formatted-text>
            <run>&lt;Sheet Name&gt;: </run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>The &quot;Sweet Spot&quot; Lead Time</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='fact_bookings+' name='federated.1ls00v01j0wdw4172bg260x8o4dy' />
          </datasources>
          <datasource-dependencies datasource='federated.1ls00v01j0wdw4172bg260x8o4dy'>
            <column aggregation='Sum' caption='BLT (Days)' datatype='integer' name='[Calculation_0977528343605248]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, [booking_date], [check_in_date])' />
            </column>
            <column caption='BLT Groups' datatype='string' name='[Calculation_0977528344236033]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_0977528343605248] &lt;= 3 THEN &quot;0-3 Days (Last Minute)&quot;&#13;&#10;ELSEIF [Calculation_0977528343605248] &lt;= 7 THEN &quot;4-7 Days (Short BLT)&quot;&#13;&#10;ELSEIF [Calculation_0977528343605248] &lt;= 14 THEN &quot;8-14 Days (Medium BLT)&quot;&#13;&#10;ELSEIF [Calculation_0977528343605248] &lt;= 30 THEN &quot;15-30 Days (Long BLT)&quot;&#13;&#10;ELSE &quot;31+ Days (Early BLT)&quot;&#13;&#10;END' />
            </column>
            <column caption='RevPAR' datatype='real' name='[Calculation_0977528345608194]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([total_room_revenue])/SUM([rooms_available_for_sale])' />
            </column>
            <column caption='ADR' datatype='real' default-format='C1054%' name='[Calculation_1171314460160002]' role='measure' type='quantitative'>
