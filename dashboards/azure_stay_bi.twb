            <column aggregation='Sum' caption='BLT (Days)' datatype='integer' name='[Calculation_0977528343605248]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, [booking_date], [check_in_date])' />
