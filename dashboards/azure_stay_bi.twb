      <aliases enabled='yes' />
      <column caption='Potential Revenue Loss' datatype='real' name='[Calculation_0454434656530432]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// คำนวณว่าถ้าคนกลุ่มที่ใช้ Promo เปลี่ยนมาจ่ายราคา Rack Rate เราจะได้เงินเพิ่มเท่าไหร่&#13;&#10;(AVG(IF [rate_name] = &apos;Rack Rate&apos; THEN [total_room_revenue]/[Calculation_0547067073482753] END) &#13;&#10;- AVG(IF [rate_name] = &apos;Seasonal Promo&apos; THEN [total_room_revenue]/[Calculation_0547067073482753] END))&#13;&#10;* COUNTD(IF [rate_name] = &apos;Seasonal Promo&apos; AND [season] = &apos;High&apos; THEN [booking_id] END)' />
      </column>
      <column aggregation='Sum' caption='LOS' datatype='integer' name='[Calculation_0547067073482753]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, [check_in_date], [check_out_date])' />
      </column>
      <column caption='Net Revenue' datatype='real' name='[Calculation_0676261753753600]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// รายได้สุทธิราย Booking&#13;&#10;[total_room_revenue] * (1 - [commission_rate])' />
      </column>
      <column caption='Leisure Booking Count' datatype='integer' name='[Calculation_0727112005345280]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [segment_id] = &apos;Leisure&apos; THEN [booking_id] END)' />
      </column>
      <column caption='Leisure ADR' datatype='real' name='[Calculation_0727112005595137]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [segment_id] = &apos;Leisure&apos; THEN [total_room_revenue] END) / [Calculation_0727112005345280]' />
      </column>
      <column caption='Booking Count' datatype='integer' name='[Calculation_0727112020979714]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='count([booking_id])' />
      </column>
      <column aggregation='Sum' caption='BLT (Days)' datatype='integer' name='[Calculation_0977528343605248]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, [booking_date], [check_in_date])' />
      </column>
      <column caption='BLT Groups' datatype='string' name='[Calculation_0977528344236033]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0977528343605248] &lt;= 3 THEN &quot;0-3 Days (Last Minute)&quot;&#13;&#10;ELSEIF [Calculation_0977528343605248] &lt;= 7 THEN &quot;4-7 Days (Short BLT)&quot;&#13;&#10;ELSEIF [Calculation_0977528343605248] &lt;= 14 THEN &quot;8-14 Days (Medium BLT)&quot;&#13;&#10;ELSEIF [Calculation_0977528343605248] &lt;= 30 THEN &quot;15-30 Days (Long BLT)&quot;&#13;&#10;ELSE &quot;31+ Days (Early BLT)&quot;&#13;&#10;END' />
      </column>
      <column caption='RevPAR' datatype='real' name='[Calculation_0977528345608194]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([total_room_revenue])/SUM([rooms_available_for_sale])' />
      </column>
      <column aggregation='Sum' caption='LOS for Hypo7.2' datatype='integer' name='[Calculation_0977528393519108]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, [check_in_date], [check_out_date])' />
      </column>
      <column caption='Occupancy %' datatype='real' default-format='p0.00%' name='[Calculation_1171314459377665]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([booking_id]) / SUM([rooms_available_for_sale])' />
      </column>
      <column caption='ADR' datatype='real' default-format='C1054%' name='[Calculation_1171314460160002]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='//SUM([Total Room Revenue]) / COUNT([Booking Id])&#13;&#10;SUM([total_room_revenue]) / COUNT([booking_id])' />
      </column>
      <column caption='Gross ADR' datatype='real' name='[Calculation_1448118965411840]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// ราคาเฉลี่ยรวม&#13;&#10;SUM([total_room_revenue])/COUNT([booking_id])' />
      </column>
      <column caption='Net ADR' datatype='real' name='[Calculation_1448118965780481]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// ราคาเฉลี่ยสุทธิ&#13;&#10;SUM([Calculation_0676261753753600]) / COUNT([booking_id])' />
      </column>
      <column aggregation='Sum' caption='LOS for Hypo7.3' datatype='integer' name='[LOS for Hypo7.2 (copy)_0977528394178565]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, [check_in_date], [check_out_date])' />
      </column>
