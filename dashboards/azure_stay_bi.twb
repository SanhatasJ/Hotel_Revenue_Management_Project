    <worksheet name='Hypo4.1'>
      <layout-options>
        <title>
          <formatted-text>
            <run>&lt;Sheet Name&gt;: </run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>วิเคราะห์ส่วนผสมราคา</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='fact_bookings+' name='federated.1ls00v01j0wdw4172bg260x8o4dy' />
          </datasources>
          <datasource-dependencies datasource='federated.1ls00v01j0wdw4172bg260x8o4dy'>
            <column caption='Booking Count' datatype='integer' name='[Calculation_0727112020979714]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='count([booking_id])' />
            </column>
            <column caption='Booking Id' datatype='string' name='[booking_id]' role='dimension' type='nominal' />
            <column-instance column='[rate_name]' derivation='None' name='[none:rate_name:nk]' pivot='key' type='nominal' />
            <column-instance column='[season]' derivation='None' name='[none:season:nk]' pivot='key' type='nominal' />
            <column-instance column='[status]' derivation='None' name='[none:status:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_0727112020979714]' derivation='User' name='[pcto:usr:Calculation_0727112020979714:qk:2]' pivot='key' type='quantitative'>
              <table-calc ordering-type='CellInPane' type='PctTotal' />
            </column-instance>
            <column caption='Rate Name' datatype='string' name='[rate_name]' role='dimension' type='nominal' />
            <column caption='Season' datatype='string' name='[season]' role='dimension' type='nominal' />
            <column caption='Status' datatype='string' name='[status]' role='dimension' type='nominal' />
          </datasource-dependencies>
          <manual-sort column='[federated.1ls00v01j0wdw4172bg260x8o4dy].[none:rate_name:nk]' direction='ASC'>
            <dictionary>
              <bucket>&quot;Rack Rate&quot;</bucket>
              <bucket>&quot;AAA Discount&quot;</bucket>
              <bucket>&quot;Non-Refundable&quot;</bucket>
              <bucket>&quot;Corporate Negotiated&quot;</bucket>
              <bucket>&quot;Seasonal Promo&quot;</bucket>
            </dictionary>
          </manual-sort>
          <filter class='categorical' column='[federated.1ls00v01j0wdw4172bg260x8o4dy].[none:season:nk]'>
            <groupfilter function='member' level='[none:season:nk]' member='&quot;High&quot;' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />
          </filter>
          <manual-sort column='[federated.1ls00v01j0wdw4172bg260x8o4dy].[none:season:nk]' direction='ASC'>
            <dictionary>
              <bucket>&quot;High&quot;</bucket>
            </dictionary>
          </manual-sort>
          <filter class='categorical' column='[federated.1ls00v01j0wdw4172bg260x8o4dy].[none:status:nk]'>
            <groupfilter function='member' level='[none:status:nk]' member='&quot;Checked-Out&quot;' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />
          </filter>
          <slices>
            <column>[federated.1ls00v01j0wdw4172bg260x8o4dy].[none:status:nk]</column>
            <column>[federated.1ls00v01j0wdw4172bg260x8o4dy].[none:season:nk]</column>
