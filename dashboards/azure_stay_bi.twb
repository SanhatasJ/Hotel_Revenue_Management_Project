    <worksheet name='Hypo3.3'>
      <layout-options>
        <title>
          <formatted-text>
            <run>&lt;Sheet Name&gt;: </run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>วิเคราะห์การเสียโอกาส</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='fact_bookings+' name='federated.1ls00v01j0wdw4172bg260x8o4dy' />
          </datasources>
          <datasource-dependencies datasource='federated.1ls00v01j0wdw4172bg260x8o4dy'>
            <column caption='Occupancy %' datatype='real' default-format='p0.00%' name='[Calculation_1171314459377665]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNT([booking_id]) / SUM([rooms_available_for_sale])' />
            </column>
            <column caption='Booking Id' datatype='string' name='[booking_id]' role='dimension' type='nominal' />
            <column caption='Date Key' datatype='date' name='[date_key]' role='dimension' type='ordinal' />
            <column caption='Day Name' datatype='string' name='[day_name]' role='dimension' type='nominal' />
            <column-instance column='[day_name]' derivation='None' name='[none:day_name:nk]' pivot='key' type='nominal' />
            <column caption='Rooms Available For Sale' datatype='integer' name='[rooms_available_for_sale]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_1171314459377665]' derivation='User' name='[usr:Calculation_1171314459377665:qk]' pivot='key' type='quantitative' />
            <column-instance column='[date_key]' derivation='Weekday' name='[wd:date_key:ok]' pivot='key' type='ordinal' />
            <column-instance column='[date_key]' derivation='Week' name='[wk:date_key:ok]' pivot='key' type='ordinal' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.1ls00v01j0wdw4172bg260x8o4dy].[none:day_name:nk]'>
            <groupfilter function='union' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate'>
              <groupfilter function='member' level='[none:day_name:nk]' member='&quot;Friday&quot;' />
              <groupfilter function='member' level='[none:day_name:nk]' member='&quot;Saturday&quot;' />
              <groupfilter function='member' level='[none:day_name:nk]' member='&quot;Sunday&quot;' />
            </groupfilter>
          </filter>
          <manual-sort column='[federated.1ls00v01j0wdw4172bg260x8o4dy].[wd:date_key:ok]' direction='ASC'>
            <dictionary>
              <bucket>6</bucket>
              <bucket>7</bucket>
              <bucket>1</bucket>
              <bucket>2</bucket>
              <bucket>3</bucket>
              <bucket>4</bucket>
              <bucket>5</bucket>
            </dictionary>
          </manual-sort>
          <slices>
            <column>[federated.1ls00v01j0wdw4172bg260x8o4dy].[none:day_name:nk]</column>
          </slices>
